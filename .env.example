# ============================================================
# PERFUME BRAND AI — Environment Variables
# Copy this file to .env.local and fill in your keys
# ============================================================

# ── FAL.AI (FLUX LoRA — REQUIRED for character stability) ───
# Step 1 of the hybrid pipeline: generates base image with MAHWOUS_MAN LoRA
# LoRA weights: https://v3b.fal.media/files/b/0a90eba7/OiQI7NS6N3neTl50fJHcC_pytorch_lora_weights.safetensors
# Trigger word: MAHWOUS_MAN
# Get your key at: https://fal.ai/dashboard/keys
FAL_KEY=your_fal_key_here

# ── GOOGLE GEMINI (Nano Banana Enhancement — REQUIRED) ──────
# Step 2 of the hybrid pipeline: enhances FLUX output to Nano Banana quality
# Get your key at: https://aistudio.google.com/app/apikey
GOOGLE_GENERATIVE_AI_API_KEY=your_gemini_api_key_here

# ── ANTHROPIC CLAUDE (Captions — Primary) ───────────────────
# Get your key at: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-your_anthropic_key_here

# ── OPENAI (Captions — Fallback if Claude fails) ────────────
# Used automatically when Claude returns 529 Overloaded
# Get your key at: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your_openai_key_here

# ── HEDRA (Video Generation — REQUIRED for videos) ──────────────────
# Your Hedra API key
HEDRA_API_KEY=your_hedra_key_here

# ── ELEVENLABS (Voice Generation — OPTIONAL, enhances TTS quality) ──
# High-quality Saudi-accented Arabic TTS
# Falls back to Hedra TTS if not configured
# Get your key at: https://elevenlabs.io/app/settings/api-keys
ELEVENLABS_API_KEY=your_elevenlabs_key_here

# ── CREATOMATE (Cloud Montage — OPTIONAL) ────────────────────────────
# Automated video montage with dynamic captions, SFX, and BGM
# Falls back to Remotion (local) if not configured
# Get your key at: https://creatomate.com/dashboard/settings
CREATOMATE_API_KEY=your_creatomate_key_here

# ── METRICOOL (Auto-Publishing — REQUIRED for smart publish) ─────
# Get your token from Metricool > Account Settings > API
# Requires $67/month plan for API access
METRICOOL_API_TOKEN=your_metricool_api_token_here
# Optional: Blog ID and User ID (auto-detected if not set)
# METRICOOL_BLOG_ID=your_blog_id
# METRICOOL_USER_ID=your_user_id

# ── IMGBB (Image Upload for Metricool — OPTIONAL but RECOMMENDED) ────
# Free image hosting for Metricool posts (fallback: catbox.moe)
# Get your free key at: https://api.imgbb.com/
IMGBB_API_KEY=your_imgbb_key_here

# NOTE: FAL_KEY is also used for Veo 3 video generation (via fal-ai/veo3)
# The same key used for image generation works for video generation too.